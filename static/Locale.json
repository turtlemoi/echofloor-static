{
  "data": [
    {
      "Key": "CARD_10101",
      "ko": "화염구",
      "en": null
    },
    {
      "Key": "CARD_10101_DESC",
      "ko": "화염구를 발사합니다. 체력이 50% 이하인 적에게 추가 피해를 줍니다.",
