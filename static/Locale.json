{
  "data": [
    {
      "Key": "CARD_10001",
      "ko": "화염구",
      "en": null
    },
    {
      "Key": "CARD_10001_DESC",
      "ko": "좁은 범위로 투사체를 발사하며, 체력이 50% 이하인 적에게 추가 피해를 줍니다.",
      "en": null
    },
    {
      "Key": "CARD_10002",
      "ko": "화염 방사",
      "en": null
    },
    {
      "Key": "CARD_10002_DESC",
      "ko": "전방에 부채꼴 모양으로 화염을 퍼부으며, 타격할 때마다 피해량이 점차 증가합니다.",
      "en": null
